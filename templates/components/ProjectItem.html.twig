<div{{ attributes }}>
    <div class="project-item">

        <div class="project-item__image {{ class|default('') }}">
            <img src="{{ asset(image) }}" alt="{{ title }}">
        </div>

        <div class="project-item__text project-item--{{ variant|default('default') }}">
            <p>
                {{ content|raw }}
            </p>
        </div>

    </div>
</div>
