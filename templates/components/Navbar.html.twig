<div{{ attributes }}>
    {% set currentRoute = app.request.attributes.get('_route') %}
    <nav class="navbar navbar-expand-lg  d-flex justify-content-center align-items-center flex-column">

        <a href="{{ path('app_home') }}" class="d-flex justify-content-center">
            <img src="{{ asset('images/logo-flaveur-header.png') }}" alt="Logo" class="img-fluid img-logo-header">
        </a>

        <div class="flex-column d-flex justify-content-center w-75">
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse  navbar-collapse justify-content-center" id="navbarNav">
                <ul class="navbar-nav px-5">
                    <li class="nav-item ">
                        <a class="nav-link active" aria-current="page" href="{{ path('app_home') }}">Accueil</a>
                    </li>
                    {% if currentRoute in ['app_project_development', 'app_editorial', 'app_personal_support'] %}

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="{{ path('app_prestations') }}"
                               id="prestationsDropdown"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Prestations
                            </a>

                            <ul class="dropdown-menu">

                                {% if currentRoute != 'app_project_development' %}
                                    <li>
                                        <a class="dropdown-item" href="{{ path('app_project_development') }}">
                                            Coordinations & animations
                                        </a>
                                    </li>
                                {% endif %}

                                {% if currentRoute != 'app_editorial' %}
                                    <li>
                                        <a class="dropdown-item" href="{{ path('app_editorial') }}">
                                            Sensibilisation & communication
                                        </a>
                                    </li>
                                {% endif %}

                                {% if currentRoute != 'app_personal_support' %}
                                    <li>
                                        <a class="dropdown-item" href="{{ path('app_personal_support') }}">
                                            Pilotage de projets & Conseil stratégique en tourisme durable
                                        </a>
                                    </li>
                                {% endif %}

                            </ul>
                        </li>

                    {% else %}

                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_prestations') }}">
                                Prestations
                            </a>
                        </li>

                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('app_contact') }}">contact</a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>
</div>
